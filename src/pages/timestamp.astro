---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---
<Layout title="Timestamp">
  <PageHeader title="Timestamp Converter" desc="Convert Unix timestamps to human-readable dates and back — with live clock" />

  <div class="tool-body">
    <!-- Live clock -->
    <div class="live-section">
      <div class="live-label">CURRENT TIME</div>
      <div class="live-grid">
        <div class="live-card big">
          <div class="lc-label">UNIX (seconds)</div>
          <div class="lc-val" id="live-unix">—</div>
          <button class="lc-copy" id="btn-copy-unix">COPY</button>
        </div>
        <div class="live-card big">
          <div class="lc-label">UNIX (ms)</div>
          <div class="lc-val" id="live-ms">—</div>
          <button class="lc-copy" id="btn-copy-ms">COPY</button>
        </div>
        <div class="live-card wide">
          <div class="lc-label">ISO 8601 / UTC</div>
          <div class="lc-val" id="live-iso">—</div>
        </div>
        <div class="live-card wide">
          <div class="lc-label">LOCAL TIME</div>
          <div class="lc-val" id="live-local">—</div>
        </div>
      </div>
    </div>

    <!-- Converters -->
    <div class="converters">
      <!-- Unix → Date -->
      <div class="conv-card">
        <div class="conv-title">Unix → Human</div>
        <div class="conv-row">
          <input type="text" id="unix-inp" placeholder="1700000000" />
          <select id="unix-unit">
            <option value="s">Seconds</option>
            <option value="ms">Milliseconds</option>
          </select>
          <button id="btn-unix-convert" class="primary">Convert</button>
        </div>
        <div id="unix-result" class="result-table" style="display:none"></div>
      </div>

      <!-- Date → Unix -->
      <div class="conv-card">
        <div class="conv-title">Human → Unix</div>
        <div class="conv-row">
          <input type="text" id="date-inp" placeholder="2024-01-15 14:30:00" />
          <button id="btn-date-convert" class="primary">Convert</button>
          <button id="btn-date-now">Now</button>
        </div>
        <div id="date-result" class="result-table" style="display:none"></div>
      </div>
    </div>

    <!-- Reference table -->
    <div class="ref-section">
      <div class="ref-label">COMMON REFERENCES</div>
      <div class="ref-table" id="ref-table"></div>
    </div>
  </div>
</Layout>

<style>
  .tool-body { padding: 20px; display: flex; flex-direction: column; gap: 20px; }

  /* Live clock */
  .live-section { display: flex; flex-direction: column; gap: 10px; }
  .live-label { font-size: 9px; letter-spacing: 0.2em; color: var(--accent); }
  .live-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .live-card {
    background: var(--surface);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
  }
  .lc-label { font-size: 9px; letter-spacing: 0.15em; color: var(--muted); }
  .lc-val {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--text);
    word-break: break-all;
    line-height: 1.3;
  }
  .lc-copy {
    position: absolute; top: 10px; right: 10px;
    font-size: 9px; padding: 2px 6px; opacity: 0;
    transition: opacity 0.12s;
  }
  .live-card:hover .lc-copy { opacity: 1; }

  /* Converters */
  .converters { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .conv-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .conv-title { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; color: var(--text); }
  .conv-row { display: flex; gap: 6px; flex-wrap: wrap; }
  .conv-row input { flex: 1; min-width: 120px; }
  .conv-row select { width: 120px; }

  .result-table { display: flex; flex-direction: column; gap: 2px; }
  .rt-row {
    display: grid; grid-template-columns: 110px 1fr auto;
    align-items: center; gap: 0;
    background: var(--surface2); border: 1px solid var(--border);
    font-size: 11px; overflow: hidden;
  }
  .rt-key {
    padding: 7px 10px; font-size: 9px; letter-spacing: 0.12em;
    color: var(--muted); border-right: 1px solid var(--border);
    background: var(--surface); white-space: nowrap;
  }
  .rt-val { padding: 7px 10px; word-break: break-all; line-height: 1.4; }
  .rt-copy {
    padding: 0 8px; border-left: 1px solid var(--border);
    font-size: 9px; letter-spacing: 0.1em; color: var(--muted);
    cursor: pointer; height: 100%; display: flex; align-items: center;
    background: transparent; border-top: none; border-right: none; border-bottom: none;
    font-family: var(--font); font-weight: 700; transition: all 0.1s;
  }
  .rt-copy:hover { color: var(--accent); background: var(--accent-dim); }

  .error-msg { font-size: 11px; color: var(--error); }

  /* Ref table */
  .ref-section { display: flex; flex-direction: column; gap: 8px; }
  .ref-label { font-size: 9px; letter-spacing: 0.2em; color: var(--muted); }
  .ref-table {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px; background: var(--border); border: 1px solid var(--border);
  }
  .ref-item {
    background: var(--surface); padding: 10px 14px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 11px; cursor: pointer; transition: background 0.1s;
  }
  .ref-item:hover { background: var(--surface2); }
  .ref-name { color: var(--muted); font-size: 10px; letter-spacing: 0.06em; }
  .ref-ts { color: var(--accent); letter-spacing: 0.04em; }

  @media (max-width: 700px) {
    .live-grid { grid-template-columns: 1fr 1fr; }
    .converters { grid-template-columns: 1fr; }
  }
</style>

<script>
  // ── Live clock ──
  function updateClock() {
    const now = new Date();
    const s  = Math.floor(now.getTime() / 1000);
    const ms = now.getTime();
    (document.getElementById('live-unix')  as HTMLElement).textContent = String(s);
    (document.getElementById('live-ms')    as HTMLElement).textContent = String(ms);
    (document.getElementById('live-iso')   as HTMLElement).textContent = now.toISOString();
    (document.getElementById('live-local') as HTMLElement).textContent = now.toLocaleString();
  }
  updateClock();
  setInterval(updateClock, 1000);

  document.getElementById('btn-copy-unix')!.addEventListener('click', async () => {
    const v = (document.getElementById('live-unix') as HTMLElement).textContent!;
    await navigator.clipboard.writeText(v);
  });
  document.getElementById('btn-copy-ms')!.addEventListener('click', async () => {
    const v = (document.getElementById('live-ms') as HTMLElement).textContent!;
    await navigator.clipboard.writeText(v);
  });

  // ── Unix → Date ──
  function makeTable(rows: Array<[string, string]>): string {
    return rows.map(([k,v]) => `
      <div class="rt-row">
        <div class="rt-key">${k}</div>
        <div class="rt-val">${v}</div>
        <button class="rt-copy" data-val="${v.replace(/"/g,'&quot;')}">COPY</button>
      </div>
    `).join('');
  }

  function attachCopyButtons(container: HTMLElement) {
    container.querySelectorAll('.rt-copy').forEach(btn => {
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText((btn as HTMLElement).dataset.val!);
        btn.textContent = 'COPIED';
        setTimeout(() => btn.textContent = 'COPY', 1200);
      });
    });
  }

  document.getElementById('btn-unix-convert')!.addEventListener('click', () => {
    const raw  = (document.getElementById('unix-inp') as HTMLInputElement).value.trim();
    const unit = (document.getElementById('unix-unit') as HTMLSelectElement).value;
    const result = document.getElementById('unix-result')!;

    if (!raw) return;
    const n = parseFloat(raw);
    if (isNaN(n)) { result.innerHTML = '<div class="error-msg">⚠ Invalid number</div>'; result.style.display = 'flex'; return; }

    const ms = unit === 'ms' ? n : n * 1000;
    const d  = new Date(ms);

    result.innerHTML = makeTable([
      ['ISO 8601',  d.toISOString()],
      ['UTC',       d.toUTCString()],
      ['Local',     d.toLocaleString()],
      ['Unix (s)',  String(Math.floor(ms/1000))],
      ['Unix (ms)', String(ms)],
      ['Year',      String(d.getUTCFullYear())],
      ['Month',     String(d.getUTCMonth() + 1)],
      ['Day',       String(d.getUTCDate())],
    ]);
    result.style.display = 'flex';
    attachCopyButtons(result);
  });

  // ── Date → Unix ──
  document.getElementById('btn-date-now')!.addEventListener('click', () => {
    (document.getElementById('date-inp') as HTMLInputElement).value =
      new Date().toISOString().slice(0, 19).replace('T', ' ');
  });

  document.getElementById('btn-date-convert')!.addEventListener('click', () => {
    const raw = (document.getElementById('date-inp') as HTMLInputElement).value.trim();
    const result = document.getElementById('date-result')!;
    if (!raw) return;

    const d = new Date(raw);
    if (isNaN(d.getTime())) {
      result.innerHTML = '<div class="error-msg">⚠ Unrecognized date format. Try: 2024-01-15 or 2024-01-15T14:30:00Z</div>';
      result.style.display = 'flex'; return;
    }

    result.innerHTML = makeTable([
      ['Unix (s)',  String(Math.floor(d.getTime()/1000))],
      ['Unix (ms)', String(d.getTime())],
      ['ISO 8601',  d.toISOString()],
      ['UTC',       d.toUTCString()],
      ['Local',     d.toLocaleString()],
    ]);
    result.style.display = 'flex';
    attachCopyButtons(result);
  });

  // ── Reference table ──
  const refs = [
    ['Unix epoch',       0],
    ['Y2K',              946684800],
    ['9/11',             1000174800],
    ['2010-01-01',       1262304000],
    ['2020-01-01',       1577836800],
    ['2024-01-01',       1704067200],
    ['2025-01-01',       1735689600],
    ['2030-01-01',       1893456000],
    ['Y2K38 (int32 max)',2147483647],
  ];
  const refTable = document.getElementById('ref-table')!;
  refTable.innerHTML = refs.map(([name, ts]) => {
    const d = new Date((ts as number) * 1000);
    return `
      <div class="ref-item" data-ts="${ts}">
        <span class="ref-name">${name}</span>
        <span class="ref-ts">${ts}</span>
      </div>
    `;
  }).join('');

  refTable.querySelectorAll('.ref-item').forEach(item => {
    item.addEventListener('click', () => {
      (document.getElementById('unix-inp') as HTMLInputElement).value = (item as HTMLElement).dataset.ts!;
      document.getElementById('btn-unix-convert')!.click();
    });
  });
</script>
